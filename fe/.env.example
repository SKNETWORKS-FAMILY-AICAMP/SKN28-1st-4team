# `development` 여도 현재 구조에서는 catalog 는 로컬 JSON을 쓰고,
# model-images / price-prediction / price-factors 는 FE_QUERY_BASE_URL 기준으로 백엔드를 호출합니다.
# 운영/배포처럼 명확히 구분하고 싶으면 `production` 같은 값으로 바꿔도 됩니다.
APP_ENV=development
SERVICE_NAME=fe
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# 로컬에서 프론트/백엔드를 각각 직접 실행할 때:
# FE_QUERY_BASE_URL=http://127.0.0.1:8000
# Docker Compose 안에서 프론트 컨테이너가 백엔드 컨테이너를 호출할 때:
# FE_QUERY_BASE_URL=http://be:8000
FE_QUERY_BASE_URL=http://127.0.0.1:8000
FE_QUERY_CATALOG_PATH=/api/v1/frontend/catalog
FE_QUERY_MODEL_IMAGE_PAGE_PATH=/api/v1/frontend/model-images
FE_QUERY_PRICE_PATH=/api/v1/frontend/price-prediction
FE_QUERY_PRICE_FACTORS_PATH=/api/v1/frontend/price-factors
FE_QUERY_TIMEOUT_SECONDS=35.0
